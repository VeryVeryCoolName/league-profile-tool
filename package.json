{
  "name": "league-profile-tool",
  "version": "3.3.0",
  "description": "Tool that interacts with the Riot LCU",
  "homepage": "https://github.com/VeryVeryCoolName/league-profile-tool",
  "author": "Manoah",
  "main": "main.js",
  "private": true,
  "scripts": {
    "sync:version": "node scripts/sync-version.js",
    "postinstall": "node scripts/ensure-electron.mjs",
    "ng": "ng",
    "start": "npm run sync:version && npm-run-all -p electron:serve ng:serve:raw",
    "typecheck:app": "node node_modules/typescript/bin/tsc -p src/tsconfig.app.json --noEmit",
    "typecheck:electron": "node node_modules/typescript/bin/tsc -p tsconfig.serve.json --noEmit",
    "typecheck": "npm-run-all -s typecheck:app typecheck:electron",
    "compile:electron": "node node_modules/typescript/bin/tsc -p tsconfig.serve.json",
    "build": "npm run sync:version && npm run compile:electron && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./",
    "build:dev": "npm run sync:version && npm run compile:electron && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./ -c dev",
    "build:prod": "npm run sync:version && npm run compile:electron && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./ -c production",
    "build:run": "npm run build:prod && electron .",
    "ng:serve": "npm run sync:version && npm run ng:serve:raw",
    "ng:serve:raw": "cross-env NODE_OPTIONS=--no-deprecation ng serve -c web",
    "electron:serve-tsc": "npm run compile:electron",
    "electron:serve": "wait-on tcp:4200 && npm run compile:electron && electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:package": "electron-builder build --publish=never",
    "electron:build": "npm run build:prod && npm run electron:package",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "eslint \"src/**/*.{ts,html}\" \"main.ts\" \"preload.ts\"",
    "verify": "npm-run-all -s lint typecheck build:prod",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.league.app",
    "productName": "League Profile Tool",
    "mac": {
      "category": "Utility"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "version.json",
      "dist/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "extraFiles": [
      "config"
    ]
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/animations": "22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cdk": "22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@angular/core": "22.0.0",
    "@angular/forms": "22.0.0",
    "@angular/language-service": "22.0.0",
    "@angular/material": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/platform-browser-dynamic": "22.0.0",
    "@types/jasmine": "6.0.0",
    "@types/node": "22.19.19",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "cross-env": "7.0.3",
    "electron": "42.3.3",
    "electron-builder": "26.8.1",
    "eslint": "^9.28.0",
    "jasmine-core": "6.2.0",
    "karma": "6.4.4",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "npm-run-all": "4.1.5",
    "rxjs": "7.8.2",
    "tslib": "2.6.2",
    "typescript": "6.0.3",
    "wait-on": "9.0.10",
    "zone.js": "0.15.1"
  },
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=11.0.0"
  },
  "browserslist": [
    "chrome 148"
  ],
  "allowScripts": {
    "electron@42.3.3": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.0": true,
    "esbuild@0.27.7": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true,
    "@parcel/watcher@2.5.6": true
  }
}
