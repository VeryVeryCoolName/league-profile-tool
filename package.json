{
  "name": "league-profile-tool",
  "version": "3.3.0",
  "description": "Tool that interacts with the Riot LCU",
  "homepage": "https://github.com/VeryVeryCoolName/league-profile-tool",
  "author": "Manoah",
  "main": "main.js",
  "private": true,
  "scripts": {
    "sync:version": "node scripts/sync-version.js",
    "postinstall": "electron-builder install-app-deps",
    "ng": "ng",
    "start": "npm run sync:version && npm-run-all -p electron:serve ng:serve",
    "build": "npm run sync:version && tsc -p tsconfig.serve.json && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./",
    "build:dev": "npm run sync:version && tsc -p tsconfig.serve.json && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./ -c dev",
    "build:prod": "npm run sync:version && tsc -p tsconfig.serve.json && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./ -c production",
    "build:run": "npm run build:prod && electron .",
    "ng:serve": "npm run sync:version && cross-env NODE_OPTIONS=--no-deprecation ng serve -c web",
    "electron:serve-tsc": "tsc -p tsconfig.serve.json",
    "electron:serve": "wait-on tcp:4200 && tsc -p tsconfig.serve.json && electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:build": "npm run build:prod && electron-builder build --publish=never",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "e2e": "npm run build:prod && cross-env TS_NODE_PROJECT='e2e/tsconfig.e2e.json' mocha --timeout 300000 --require ts-node/register e2e/**/*.e2e.ts",
    "version": "conventional-changelog -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
    "lint": "ng lint",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.league.app",
    "productName": "League Profile Tool",
    "mac": {
      "category": "Utility"
    },
    "files": [
      "**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "extraFiles": [
      "config"
    ]
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "20.0.0",
    "@angular-devkit/build-angular": "20.3.27",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/animations": "20.3.24",
    "@angular/cdk": "20.2.14",
    "@angular/cli": "20.3.27",
    "@angular/common": "20.3.24",
    "@angular/compiler": "20.3.24",
    "@angular/compiler-cli": "20.3.24",
    "@angular/core": "20.3.24",
    "@angular/forms": "20.3.24",
    "@angular/language-service": "20.3.24",
    "@angular/material": "20.2.14",
    "@angular/platform-browser": "20.3.24",
    "@angular/platform-browser-dynamic": "20.3.24",
    "@angular/router": "20.3.24",
    "@ngx-translate/core": "13.0.0",
    "@ngx-translate/http-loader": "6.0.0",
    "@types/jasmine": "3.6.7",
    "@types/jasminewd2": "2.0.8",
    "@types/mocha": "8.2.1",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@typescript-eslint/types": "8.57.1",
    "@typescript-eslint/utils": "8.57.1",
    "chai": "4.3.4",
    "conventional-changelog-cli": "2.1.1",
    "core-js": "3.49.0",
    "cross-env": "7.0.3",
    "electron": "42.3.3",
    "electron-builder": "26.8.1",
    "electron-reload": "1.5.0",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsdoc": "50.8.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "jasmine-core": "3.7.1",
    "jasmine-spec-reporter": "6.0.0",
    "karma": "6.4.4",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-electron": "7.3.0",
    "karma-jasmine": "4.0.1",
    "karma-jasmine-html-reporter": "1.5.4",
    "mocha": "8.3.2",
    "npm-run-all": "4.1.5",
    "rxjs": "6.6.6",
    "spectron": "14.0.0",
    "ts-node": "10.9.2",
    "tslib": "2.6.2",
    "typescript": "5.9.3",
    "wait-on": "5.3.0",
    "webdriver-manager": "12.1.8",
    "zone.js": "0.15.1"
  },
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  },
  "browserslist": [
    "chrome 114"
  ]
}
