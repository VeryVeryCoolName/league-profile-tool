{
  "name": "league-profile-tool",
  "version": "3.3.0",
  "description": "Tool that interacts with the Riot LCU",
  "homepage": "https://github.com/VeryVeryCoolName/league-profile-tool",
  "author": "Manoah",
  "main": "main.js",
  "private": true,
  "scripts": {
    "sync:version": "node scripts/sync-version.js",
    "postinstall": "electron-builder install-app-deps",
    "ng": "ng",
    "start": "npm run sync:version && npm-run-all -p electron:serve ng:serve",
    "build": "npm run sync:version && tsc -p tsconfig.serve.json && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./",
    "build:dev": "npm run sync:version && tsc -p tsconfig.serve.json && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./ -c dev",
    "build:prod": "npm run sync:version && tsc -p tsconfig.serve.json && cross-env NODE_OPTIONS=--no-deprecation ng build --base-href ./ -c production",
    "build:run": "npm run build:prod && electron .",
    "ng:serve": "npm run sync:version && cross-env NODE_OPTIONS=--no-deprecation ng serve -c web",
    "electron:serve-tsc": "tsc -p tsconfig.serve.json",
    "electron:serve": "wait-on tcp:4200 && tsc -p tsconfig.serve.json && electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:build": "npm run build:prod && electron-builder build --publish=never",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "eslint \"src/app/**/*.component.ts\" \"src/app/**/*.module.ts\" \"src/app/**/*.pipe.ts\" \"src/app/**/*.service.ts\" \"src/app/app-version.ts\" \"src/app/core/services/match-tools/matchup-provider.ts\" \"main.ts\"",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.league.app",
    "productName": "League Profile Tool",
    "mac": {
      "category": "Utility"
    },
    "files": [
      "**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "extraFiles": [
      "config"
    ]
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/animations": "22.0.0",
    "@angular/cdk": "22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@angular/core": "22.0.0",
    "@angular/forms": "22.0.0",
    "@angular/language-service": "22.0.0",
    "@angular/material": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/platform-browser-dynamic": "22.0.0",
    "@angular/router": "22.0.0",
    "@ngx-translate/core": "13.0.0",
    "@ngx-translate/http-loader": "6.0.0",
    "@types/jasmine": "3.6.7",
    "@types/node": "22.19.19",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@typescript-eslint/types": "8.60.1",
    "@typescript-eslint/utils": "8.60.1",
    "core-js": "3.49.0",
    "cross-env": "7.0.3",
    "electron": "42.3.3",
    "electron-builder": "26.8.1",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsdoc": "50.8.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "3.7.1",
    "jasmine-spec-reporter": "6.0.0",
    "karma": "6.4.4",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-electron": "7.3.0",
    "karma-jasmine": "4.0.1",
    "karma-jasmine-html-reporter": "1.5.4",
    "npm-run-all": "4.1.5",
    "rxjs": "7.8.2",
    "tslib": "2.6.2",
    "typescript": "6.0.3",
    "wait-on": "9.0.10",
    "zone.js": "0.15.1"
  },
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=11.0.0"
  },
  "browserslist": [
    "chrome 114"
  ]
}
