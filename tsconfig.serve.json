{
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "module": "Node16",
    "moduleResolution": "node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "target": "ES2022",
    "types": [
      "node"
    ],
    "lib": [
      "es2020",
      "dom"
    ]
  },
  "files": [
    "main.ts",
    "preload.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}
